<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.1">
    <persistence-unit name="quizlyPU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.quizly.models.Prof</class>
        <class>com.example.quizly.models.Quiz</class>
        <class>com.example.quizly.models.Question</class>
        <class>com.example.quizly.models.Choice</class>
        <class>com.example.quizly.models.Session</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver" />
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/quizly_db" />
            <property name="jakarta.persistence.jdbc.user" value="mac" />
            <property name="jakarta.persistence.jdbc.password" value="Anasgamer@2" />
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.hbm2ddl.auto" value="update" />
        </properties>

    </persistence-unit>
</persistence>
